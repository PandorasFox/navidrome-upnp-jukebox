# Navidrome connection (required)
NAVIDROME_URL=http://cerberus.magic:4533
NAVIDROME_USER=jukebox
NAVIDROME_PASS=your_password_here

# UPnP renderer address (required)
# Format: hostname-or-ip:port (e.g., yamaha.local:80 or 192.168.1.100:80)
RENDERER_ADDRESS=yamaha.local:80

# Server listen address (optional, defaults to :8080)
LISTEN=:8080

# SQLite database path (optional, defaults to queue.db)
DB_PATH=/data/queue.db
